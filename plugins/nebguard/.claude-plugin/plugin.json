{
  "name": "nebguard",
  "description": "AI guardrails engine for Claude Code — compiled Go binary with embedded skills, agents, playbooks, and decision criteria. Zero IP on disk between sessions.",
  "version": "1.3.0",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/nebguard pre-tool-use --matcher bash",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/nebguard pre-tool-use --matcher edit",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/nebguard post-tool-use --matcher bash",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/nebguard post-tool-use --matcher edit",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/nebguard post-tool-use --matcher skill",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/nebguard session start",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/nebguard session end",
            "timeout": 15,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/nebguard stop",
            "timeout": 15,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/nebguard prompt",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/nebguard pre-compact",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ]
  }
}
